{
  "name": "pommy-static-site",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "npm run build:astryx && npm run build:seo",
    "build:astryx": "vite build",
    "build:seo": "node scripts/generate-seo.cjs",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs",
    "prerender": "node scripts/prerender-public.cjs",
    "audit": "node scripts/audit-pommy.cjs",
    "test:seo": "node scripts/validate-seo.cjs",
    "test:seo:browser": "node scripts/validate-seo-browser.cjs http://127.0.0.1:8765",
    "test:seo:visual": "node scripts/capture-seo-regression.cjs http://127.0.0.1:8765",
    "test:seo:visual:compare": "node scripts/compare-seo-regression.cjs .codex-screenshots/seo-final-baseline .codex-screenshots/seo-final-current",
    "test:db:static": "node scripts/test-supabase-static.cjs",
    "test:db:behavior": "psql -v ON_ERROR_STOP=1 -f supabase/tests/database-behavior.sql",
    "test:browser": "node scripts/validate-pommy.cjs http://127.0.0.1:8765",
    "test:browser:live-data": "node scripts/validate-supabase-public.cjs http://127.0.0.1:8765",
    "test:admin": "node scripts/validate-admin.cjs http://127.0.0.1:8765",
    "test:motion": "node scripts/validate-motion-links.cjs http://127.0.0.1:8765"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.7",
    "playwright": "1.61.1",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.7",
    "@astryxdesign/theme-neutral": "^0.1.7",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  }
}
